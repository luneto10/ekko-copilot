# Copy this file to .env (kept in the desktop-client app folder OR repo root) and fill in.
# These values are read ONLY by the Electron main process. They are never exposed to the renderer.

# --- Azure AI Speech (real-time transcription) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# --- Azure OpenAI (memory.md compilation + sales tactics) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Demo tuning ---
# How many transcribed words accumulate before the Call Intelligence (memory.md)
# is recompiled. Lower = updates sooner (good for demos). Default 40.
MEMORY_FLUSH_WORDS=40

# --- Microsoft Work IQ (mocked by default; set WORKIQ_MODE=real to hit a live endpoint) ---
WORKIQ_MODE=mock
WORKIQ_API_BASE=
WORKIQ_BEARER_TOKEN=
