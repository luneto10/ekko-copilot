{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "WorkIQ: Install",
      "detail": "Install all workspace dependencies (npm install at the repo root).",
      "type": "shell",
      "command": "npm install",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "WorkIQ: Dev",
      "detail": "Start the app: Vite widget (127.0.0.1:5173) + Electron main process.",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "WorkIQ: Stop",
      "detail": "Stop everything: free port 5173 and kill the WorkIQ Electron processes.",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\stop-workiq.ps1"
      ],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
